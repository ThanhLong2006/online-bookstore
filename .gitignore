# Spring Boot specific
backend/application-dev.yml
backend/application-prod.yml
backend/src/main/resources/application-dev.*
backend/src/main/resources/application-prod.*

# Logs Spring
backend/*.log
backend/logs/

# ==================== General Java ====================
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz

# ==================== Không ignore những file quan trọng ====================
# Giữ lại file mẫu để người khác biết cấu hình
!**/application.yml.example
!**/application.properties.example
!**/.env.example